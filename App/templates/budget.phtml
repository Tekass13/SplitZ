<h1>Mes Budgets</h1>

<section class="budgets-container">
    <!-- Affichage des budgets -->
    <?php if (!empty($budgets)) : ?>
        <div class="budgets-list">
            <?php foreach ($budgets as $budget) : ?>
                <div class="budget-card">
                    <div class="budget-header">
                        <h2><?= htmlspecialchars($budget['title'], ENT_QUOTES, 'UTF-8') ?></h2>
                        <div class="budget-price">
                            <p class="price-label">Total:</p>
                            <p class="price-value"><?= number_format($budget['total_price'], 2, ',', ' ') ?> €</p>
                        </div>
                    </div>
                    
                    <!-- Affichage des catégories du budget -->
                    <?php if (!empty($budget['categories'])) : ?>
                        <div class="categories-list">
                            <?php foreach ($budget['categories'] as $category) : ?>
                                <div class="category-item">
                                    <div class="category-icon">
                                        <i class="fa <?= $this->getCategoryIcon($category['type']) ?>"></i>
                                    </div>
                                    <div class="category-details">
                                        <p class="category-name"><?= htmlspecialchars($category['name'], ENT_QUOTES, 'UTF-8') ?></p>
                                        <p class="category-price"><?= number_format($category['price'], 2, ',', ' ') ?> €</p>
                                        <p class="category-date"><?= htmlspecialchars($budget['created_at'], ENT_QUOTES, 'UTF-8') ?></p>
                                    </div>
                                    <?php if (!empty($category['contact_id'])) : ?>
                                        <div class="category-contact">
                                            <p class="contact-name"><?= htmlspecialchars($category['contact']['username'], ENT_QUOTES, 'UTF-8') ?></p>
                                        </div>
                                    <?php endif; ?>
                                </div>
                            <?php endforeach; ?>
                        </div>
                    <?php else : ?>
                        <p class="no-categories">Aucune catégorie ajoutée à ce budget</p>
                    <?php endif; ?>
                    
                    <!-- Actions sur le budget -->
                    <div class="budget-actions">
                        <a href="index.php?route=edit-budget&id=<?= $budget['id'] ?>" class="button-secondary">Modifier</a>
                        <a href="index.php?route=delete-budget&id=<?= $budget['id'] ?>" class="button-danger" onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce budget?')">Supprimer</a>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    <?php else : ?>
        <div class="no-budgets">
            <p>Vous n'avez pas encore créé de budget.</p>
        </div>
    <?php endif; ?>
    
    <!-- Bouton pour ajouter un nouveau budget -->
    <div class="add-budget">
        <a href="index.php?route=add-budget" class="button">
            <i class="fa fa-plus"></i> Ajouter un nouveau budget
        </a>
    </div>
</section>